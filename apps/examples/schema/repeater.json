{
  "spec_version": "1.0",
  "title": "tater - repeater",
  "description": "Repeatable list widgets — list, tabs, and accordion styles.",
  "instructions": "Demonstrates the three repeater widget styles for the same item schema:\n\n- **List** — items as a vertical stack of cards\n- **Tabs** — items as switchable tabs\n- **Accordion** — items as collapsible sections\n",
  "data_schema": [
    {
      "id": "pets_list",
      "type": "repeater",
      "label": "Pets (List)",
      "description": "Items shown as a vertical stack of cards.",
      "widget": {"item_label": "Pet"},
      "item_fields": [
        {"id": "kind", "type": "choice", "options": ["cat", "dog", "fish"], "label": "Pet Type"},
        {"id": "neutered", "type": "boolean", "label": "Neutered / spayed"},
        {"id": "indoor", "type": "boolean", "label": "Indoor", "widget": {"type": "switch"}}
      ]
    },
    {
      "id": "pets_tabs",
      "type": "repeater",
      "label": "Pets (Tabs)",
      "description": "Items shown as switchable tabs.",
      "widget": {"type": "tabs", "item_label": "Pet"},
      "item_fields": [
        {"id": "kind", "type": "choice", "options": ["cat", "dog", "fish"], "label": "Pet Type"},
        {"id": "neutered", "type": "boolean", "label": "Neutered / spayed"},
        {"id": "indoor", "type": "boolean", "label": "Indoor", "widget": {"type": "switch"}}
      ]
    },
    {
      "id": "pets_accordion",
      "type": "repeater",
      "label": "Pets (Accordion)",
      "description": "Items shown as collapsible sections.",
      "widget": {"type": "accordion", "item_label": "Pet"},
      "item_fields": [
        {"id": "kind", "type": "choice", "options": ["cat", "dog", "fish"], "label": "Pet Type"},
        {"id": "neutered", "type": "boolean", "label": "Neutered / spayed"},
        {"id": "indoor", "type": "boolean", "label": "Indoor", "widget": {"type": "switch"}}
      ]
    }
  ]
}
