{
  "spec_version": "1.0",
  "title": "tater - multiple",
  "description": "Schema showcasing all supported field types with full UI hints.",
  "instructions": "This is a widget showcase. Fill in each field using the appropriate widget type: radio buttons, segmented controls, checkboxes, text inputs, sliders, and multi-select dropdowns.",
  "data_schema": [
    {
      "id": "pet_type",
      "type": "choice",
      "options": ["cat", "dog", "fish"],
      "required": true,
      "label": "Pet Type",
      "description": "What type of pet is mentioned?",
      "widget": {"type": "radio_group"}
    },
    {
      "id": "sentiment",
      "type": "choice",
      "options": ["positive", "negative", "neutral"],
      "required": true,
      "label": "Sentiment",
      "description": "Overall sentiment of the document"
    },
    {
      "id": "location",
      "type": "choice",
      "options": ["home", "park", "vet", "shelter", "other"],
      "required": true,
      "label": "Location",
      "description": "Where is the pet located?",
      "widget": {"type": "select"}
    },
    {
      "id": "is_cute",
      "type": "boolean",
      "label": "Is cute?",
      "description": "Check if this pet is cute"
    },
    {
      "id": "is_indoor",
      "type": "boolean",
      "label": "Indoor?",
      "description": "Is this an indoor setting?",
      "widget": {"type": "switch"}
    },
    {
      "id": "favorite_colors",
      "type": "multi_choice",
      "options": ["red", "green", "blue", "yellow", "purple"],
      "required": true,
      "label": "Favorite Colors",
      "description": "Select one or more favorite colors"
    },
    {
      "id": "traits",
      "type": "multi_choice",
      "options": ["friendly", "playful", "lazy", "energetic", "shy"],
      "required": true,
      "label": "Traits",
      "description": "Select all traits that apply",
      "widget": {"type": "chip_group"}
    },
    {
      "id": "pet_age",
      "type": "numeric",
      "required": true,
      "label": "Pet Age",
      "description": "How old is the pet?",
      "widget": {"type": "number_input", "min_value": 0, "max_value": 50, "step": 0.1}
    },
    {
      "id": "confidence",
      "type": "numeric",
      "required": true,
      "default": 50,
      "label": "Confidence",
      "description": "How confident are you in this annotation?",
      "widget": {"type": "slider", "min_value": 0, "max_value": 100, "step": 1}
    },
    {
      "id": "age_range",
      "type": "range_slider",
      "label": "Age Range",
      "description": "Estimated age range of the pet",
      "widget": {"min_value": 0, "max_value": 30, "step": 1}
    },
    {
      "id": "reviewer_note",
      "type": "text",
      "required": true,
      "label": "Reviewer note",
      "description": "Optional short note about this document",
      "widget": {"type": "text_input", "placeholder": "Enter a short note"}
    },
    {
      "id": "detailed_notes",
      "type": "text",
      "label": "Detailed Notes",
      "description": "Extended notes about this document",
      "widget": {"type": "text_area", "placeholder": "Enter detailed notes...", "min_rows": 4}
    }
  ]
}
