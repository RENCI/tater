{
  "spec_version": "1.0",
  "title": "tater - deep nested",
  "description": "Two levels of GroupWidget nesting demonstrating deep schema paths.",
  "instructions": "Fill in the document mood. Expand 'Address' then 'Location' to reach nested fields.",
  "data_schema": [
    {
      "id": "document_mood",
      "type": "choice",
      "options": [
        "positive",
        "negative",
        "neutral"
      ],
      "widget": {
        "type": "segmented_control",
        "label": "Document Mood",
        "description": "Top-level field"
      }
    },
    {
      "id": "address",
      "type": "group",
      "fields": [
        {
          "id": "pet_type",
          "type": "choice",
          "options": [
            "cat",
            "dog",
            "fish"
          ],
          "widget": {
            "type": "radio_group",
            "label": "Pet Type at Address",
            "orientation": "vertical"
          }
        },
        {
          "id": "location",
          "type": "group",
          "fields": [
            {
              "id": "location_mood",
              "type": "choice",
              "options": [
                "cheerful",
                "stressful",
                "peaceful"
              ],
              "widget": {
                "type": "segmented_control",
                "label": "Location Atmosphere",
                "description": "Three levels deep!"
              }
            }
          ],
          "widget": {
            "label": "Location Details",
            "description": "Second level of nesting"
          }
        }
      ],
      "widget": {
        "label": "Address",
        "description": "First level of nesting"
      }
    }
  ]
}