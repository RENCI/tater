{
  "spec_version": "1.0",
  "title": "tater - nested",
  "description": "Single-level grouped fields with labels, descriptions, and widget hints.",
  "instructions": "1. Set the **Document Mood** (top level)\n2. Expand **Owner Information** to reveal:\n   - Owner name\n   - Contact info\n   - Address details\n",
  "data_schema": [
    {
      "id": "document_mood",
      "type": "choice",
      "options": [
        "positive",
        "negative",
        "neutral"
      ],
      "widget": {
        "type": "segmented_control",
        "label": "Document Mood",
        "description": "Overall tone of the entire document"
      }
    },
    {
      "id": "owner",
      "type": "group",
      "fields": [
        {
          "id": "owner_mood",
          "type": "choice",
          "options": [
            "happy",
            "anxious",
            "calm"
          ],
          "widget": {
            "type": "segmented_control",
            "label": "Owner Mood"
          }
        },
        {
          "id": "pet_type",
          "type": "choice",
          "options": [
            "cat",
            "dog",
            "fish"
          ],
          "widget": {
            "type": "radio_group",
            "label": "Owner's Pet Type",
            "orientation": "vertical"
          }
        }
      ],
      "widget": {
        "label": "Owner Information",
        "description": "Information about the pet owner"
      }
    }
  ]
}