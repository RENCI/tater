{
  "spec_version": "1.0",
  "title": "tater - nested",
  "description": "Single-level grouped fields with labels, descriptions, and widget hints.",
  "instructions": "Fill in the document mood at the top level. Expand the 'Owner Information' group to enter owner details.",
  "data_schema": [
    {
      "id": "document_mood",
      "type": "choice",
      "options": ["positive", "negative", "neutral"],
      "label": "Document Mood",
      "description": "Overall tone of the entire document"
    },
    {
      "id": "owner",
      "type": "group",
      "label": "Owner Information",
      "description": "Information about the pet owner",
      "fields": [
        {
          "id": "owner_mood",
          "type": "choice",
          "options": ["happy", "anxious", "calm"],
          "label": "Owner Mood"
        },
        {
          "id": "pet_type",
          "type": "choice",
          "options": ["cat", "dog", "fish"],
          "label": "Owner's Pet Type",
          "widget": {"type": "radio_group", "orientation": "vertical"}
        }
      ]
    }
  ]
}
