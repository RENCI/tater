{
  "spec_version": "1.0",
  "title": "tater - divider",
  "description": "Demonstrates DividerWidget for named section breaks.",
  "data_schema": [
    {
      "widget": {
        "type": "divider",
        "label": "Mood Assessment",
        "description": "Emotional and energy state of the pet"
      }
    },
    {
      "id": "pet_mood",
      "type": "choice",
      "options": [
        "happy",
        "anxious",
        "calm"
      ],
      "widget": {
        "type": "segmented_control",
        "label": "Pet Mood",
        "required": true
      }
    },
    {
      "id": "energy_level",
      "type": "choice",
      "options": [
        "low",
        "medium",
        "high"
      ],
      "widget": {
        "type": "radio_group",
        "label": "Energy Level",
        "required": true,
        "orientation": "horizontal"
      }
    },
    {
      "widget": {
        "type": "divider",
        "label": "Actions"
      }
    },
    {
      "id": "needs_attention",
      "type": "boolean",
      "widget": {
        "type": "checkbox",
        "label": "Needs Attention?"
      }
    },
    {
      "id": "notes",
      "type": "text",
      "widget": {
        "type": "text_area",
        "label": "Notes",
        "description": "Any additional observations"
      }
    }
  ]
}