{
  "spec_version": "1.0",
  "title": "tater - divider",
  "description": "Demonstrates DividerWidget for named section breaks.",
  "data_schema": [
    {
      "type": "divider",
      "label": "Mood Assessment",
      "description": "Emotional and energy state of the pet"
    },
    {
      "id": "pet_mood",
      "type": "choice",
      "options": ["happy", "anxious", "calm"],
      "required": true,
      "label": "Pet Mood"
    },
    {
      "id": "energy_level",
      "type": "choice",
      "options": ["low", "medium", "high"],
      "required": true,
      "label": "Energy Level",
      "widget": {"type": "radio_group", "orientation": "horizontal"}
    },
    {
      "type": "divider",
      "label": "Actions"
    },
    {
      "id": "needs_attention",
      "type": "boolean",
      "label": "Needs Attention?"
    },
    {
      "id": "notes",
      "type": "text",
      "label": "Notes",
      "description": "Any additional observations",
      "widget": {"type": "text_area"}
    }
  ]
}
