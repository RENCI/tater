{
  "spec_version": "1.0",
  "title": "tater - conditional (choice-based)",
  "description": "Conditional fields based on option widget values.",
  "data_schema": [
    {
      "id": "pet_type",
      "type": "choice",
      "options": ["cat", "dog", "fish"],
      "required": true,
      "label": "Pet Type",
      "description": "Select the pet type to see relevant fields",
      "widget": {"type": "select"}
    },
    {
      "id": "dog_breed",
      "type": "text",
      "label": "Dog Breed",
      "widget": {"type": "text_input", "placeholder": "e.g. Golden Retriever"},
      "conditional_on": {"field": "pet_type", "value": "dog"}
    },
    {
      "id": "dog_temperament",
      "type": "choice",
      "options": ["calm", "playful", "aggressive"],
      "label": "Dog Temperament",
      "widget": {"type": "radio_group", "orientation": "horizontal"},
      "conditional_on": {"field": "pet_type", "value": "dog"}
    },
    {
      "id": "cat_color",
      "type": "text",
      "label": "Cat Color",
      "widget": {"type": "text_input", "placeholder": "e.g. Orange tabby"},
      "conditional_on": {"field": "pet_type", "value": "cat"}
    },
    {
      "id": "fish_tank_size",
      "type": "choice",
      "options": ["small", "medium", "large"],
      "label": "Tank Size",
      "description": "What size tank is the fish in?",
      "widget": {"type": "select"},
      "conditional_on": {"field": "pet_type", "value": "fish"}
    },
    {
      "id": "additional_notes",
      "type": "text",
      "label": "Additional Notes",
      "widget": {"type": "text_area", "placeholder": "Any other notes about the pet..."}
    }
  ]
}
