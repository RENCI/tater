{
  "spec_version": "1.0",
  "title": "tater - conditional (choice-based)",
  "description": "Conditional fields based on option widget values.",
  "instructions": "Select a pet type to reveal type-specific fields. Dogs show breed/temperament, cats show color, fish show tank size.",
  "data_schema": [
    {
      "id": "pet_type",
      "type": "choice",
      "options": [
        "cat",
        "dog",
        "fish"
      ],
      "widget": {
        "type": "select",
        "label": "Pet Type",
        "description": "Select the pet type to see relevant fields",
        "required": true
      }
    },
    {
      "id": "dog_breed",
      "type": "text",
      "widget": {
        "type": "text_input",
        "label": "Dog Breed",
        "placeholder": "e.g. Golden Retriever",
        "conditional_on": {
          "field": "pet_type",
          "value": "dog"
        }
      }
    },
    {
      "id": "dog_temperament",
      "type": "choice",
      "options": [
        "calm",
        "playful",
        "aggressive"
      ],
      "widget": {
        "type": "radio_group",
        "label": "Dog Temperament",
        "orientation": "horizontal",
        "conditional_on": {
          "field": "pet_type",
          "value": "dog"
        }
      }
    },
    {
      "id": "cat_color",
      "type": "text",
      "widget": {
        "type": "text_input",
        "label": "Cat Color",
        "placeholder": "e.g. Orange tabby",
        "conditional_on": {
          "field": "pet_type",
          "value": "cat"
        }
      }
    },
    {
      "id": "fish_tank_size",
      "type": "choice",
      "options": [
        "small",
        "medium",
        "large"
      ],
      "widget": {
        "type": "select",
        "label": "Tank Size",
        "description": "What size tank is the fish in?",
        "conditional_on": {
          "field": "pet_type",
          "value": "fish"
        }
      }
    },
    {
      "id": "additional_notes",
      "type": "text",
      "widget": {
        "type": "text_area",
        "label": "Additional Notes",
        "placeholder": "Any other notes about the pet..."
      }
    }
  ]
}