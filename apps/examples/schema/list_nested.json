{
  "spec_version": "1.0",
  "title": "tater - list (nested)",
  "description": "List of structured items, each with multiple fields.",
  "data_schema": [
    {
      "id": "medications",
      "type": "listable",
      "label": "Medications",
      "description": "Add each medication entry with name, route, and frequency.",
      "widget": {
        "item_label": "Medication"
      },
      "item_fields": [
        {
          "id": "name",
          "type": "text",
          "label": "Medication Name",
          "placeholder": "e.g. Ibuprofen"
        },
        {
          "id": "route",
          "type": "choice",
          "options": ["oral", "iv", "topical", "inhaled"],
          "label": "Route",
          "widget": {"type": "radio_group", "orientation": "horizontal"}
        },
        {
          "id": "frequency",
          "type": "choice",
          "options": ["once daily", "twice daily", "as needed"],
          "label": "Frequency"
        }
      ]
    }
  ]
}
