{
  "spec_version": "1.0",
  "title": "tater - list (nested)",
  "description": "List of structured items, each with multiple fields.",
  "instructions": "Add vet visit records. Each visit has date, reason, and notes. Click 'Add' to create new visits or delete to remove.",
  "data_schema": [
    {
      "id": "vet_visits",
      "type": "listable",
      "label": "Vet Visits",
      "description": "Add each veterinary visit with date, reason, and notes.",
      "widget": {
        "item_label": "Visit"
      },
      "item_fields": [
        {
          "id": "date",
          "type": "text",
          "label": "Visit Date",
          "placeholder": "e.g. 2024-01-15"
        },
        {
          "id": "reason",
          "type": "choice",
          "options": ["checkup", "vaccination", "illness", "injury"],
          "label": "Visit Reason",
          "widget": {"type": "radio_group", "orientation": "horizontal"}
        },
        {
          "id": "notes",
          "type": "text",
          "label": "Visit Notes",
          "placeholder": "Additional details about the visit...",
          "widget": {"type": "text_area"}
        }
      ]
    }
  ]
}
