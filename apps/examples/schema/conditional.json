{
  "spec_version": "1.0",
  "title": "tater - conditional",
  "description": "Conditional fields with labels, descriptions, and widget hints.",
  "instructions": "Try toggling these controls:\n\n- **Is Indoor?** - Reveals indoor-specific fields\n- **Has Special Needs?** - Reveals special care options\n- **Has Microchip?** - Reveals microchip details\n\nFields appear/disappear based on your selections.\n",
  "data_schema": [
    {
      "id": "is_indoor",
      "type": "boolean",
      "label": "Indoor?",
      "description": "Is this an indoor setting?",
      "widget": {"type": "switch"}
    },
    {
      "id": "indoor_location",
      "type": "text",
      "label": "Indoor Location",
      "widget": {"type": "text_input", "placeholder": "e.g. living room, kitchen"},
      "conditional_on": {"field": "is_indoor", "value": true}
    },
    {
      "id": "has_health_issue",
      "type": "boolean",
      "label": "Has health issue?"
    },
    {
      "id": "health_description",
      "type": "text",
      "label": "Health Description",
      "widget": {"type": "text_area", "placeholder": "Describe the health issue..."},
      "conditional_on": {"field": "has_health_issue", "value": true}
    },
    {
      "id": "is_stray",
      "type": "boolean",
      "label": "Is stray?",
      "widget": {"type": "switch"}
    },
    {
      "id": "rescue_org",
      "type": "text",
      "label": "Rescue Organisation",
      "widget": {"type": "text_input", "placeholder": "Organisation name"},
      "conditional_on": {"field": "is_stray", "value": true}
    },
    {
      "id": "rescue_notes",
      "type": "text",
      "label": "Rescue Notes",
      "widget": {"type": "text_area", "placeholder": "Additional notes about rescue..."},
      "conditional_on": {"field": "is_stray", "value": true}
    }
  ]
}
