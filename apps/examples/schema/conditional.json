{
  "spec_version": "1.0",
  "title": "tater - conditional",
  "description": "Conditional fields with labels, descriptions, and widget hints.",
  "instructions": "Try toggling these controls:\n\n- **Is Indoor?** - Reveals indoor-specific fields\n- **Has Special Needs?** - Reveals special care options\n- **Has Microchip?** - Reveals microchip details\n\nFields appear/disappear based on your selections.\n",
  "data_schema": [
    {
      "id": "is_indoor",
      "type": "boolean",
      "widget": {
        "type": "switch",
        "label": "Indoor?",
        "description": "Is this an indoor setting?"
      }
    },
    {
      "id": "indoor_location",
      "type": "text",
      "widget": {
        "type": "text_input",
        "label": "Indoor Location",
        "placeholder": "e.g. living room, kitchen",
        "conditional_on": {
          "field": "is_indoor",
          "value": true
        }
      }
    },
    {
      "id": "has_health_issue",
      "type": "boolean",
      "widget": {
        "type": "checkbox",
        "label": "Has health issue?"
      }
    },
    {
      "id": "health_description",
      "type": "text",
      "widget": {
        "type": "text_area",
        "label": "Health Description",
        "placeholder": "Describe the health issue...",
        "conditional_on": {
          "field": "has_health_issue",
          "value": true
        }
      }
    },
    {
      "id": "is_stray",
      "type": "boolean",
      "widget": {
        "type": "switch",
        "label": "Is stray?"
      }
    },
    {
      "id": "rescue_org",
      "type": "text",
      "widget": {
        "type": "text_input",
        "label": "Rescue Organisation",
        "placeholder": "Organisation name",
        "conditional_on": {
          "field": "is_stray",
          "value": true
        }
      }
    },
    {
      "id": "rescue_notes",
      "type": "text",
      "widget": {
        "type": "text_area",
        "label": "Rescue Notes",
        "placeholder": "Additional notes about rescue...",
        "conditional_on": {
          "field": "is_stray",
          "value": true
        }
      }
    }
  ]
}