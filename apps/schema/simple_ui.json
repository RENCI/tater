{
  "spec_version": "1.0",
  "title": "tater - simple",
  "description": "Sentiment and relevance annotation with explicit widget hints.",
  "data_schema": [
    {
      "id": "sentiment",
      "type": "single_choice",
      "options": ["positive", "negative", "neutral"],
      "required": true,
      "label": "Sentiment",
      "description": "Overall sentiment of the document"
    },
    {
      "id": "is_relevant",
      "type": "boolean",
      "label": "Relevant?",
      "description": "Is this document relevant?"
    }
  ]
}
