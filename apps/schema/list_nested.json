{
  "spec_version": "1.0",
  "title": "tater - list (nested)",
  "description": "List of structured items, each with multiple fields.",
  "data_schema": [
    {
      "id": "medications",
      "type": "list",
      "label": "Medications",
      "widget": {
        "add_label": "Add Medication",
        "delete_label": "Remove",
        "initial_count": 1
      },
      "item_fields": [
        {
          "id": "name",
          "type": "free_text",
          "label": "Medication Name",
          "placeholder": "e.g. Ibuprofen"
        },
        {
          "id": "route",
          "type": "single_choice",
          "options": ["oral", "iv", "topical", "inhaled"],
          "label": "Route",
          "widget": {"type": "radio_group", "orientation": "horizontal"}
        },
        {
          "id": "frequency",
          "type": "single_choice",
          "options": ["once daily", "twice daily", "as needed"],
          "label": "Frequency"
        }
      ]
    }
  ]
}
