{
  "spec_version": "1.0",
  "title": "tater - simple (mixed)",
  "description": "Sentiment shown as a vertical radio group; relevance uses the default widget.",
  "data_schema": [
    {
      "id": "sentiment",
      "type": "single_choice",
      "options": ["positive", "negative", "neutral"],
      "required": true,
      "label": "Sentiment",
      "description": "Overall sentiment of the document",
      "widget": {"type": "radio_group", "orientation": "vertical"}
    },
    {
      "id": "is_relevant",
      "type": "boolean",
      "label": "Relevant?",
      "description": "Is this document relevant?"
    }
  ]
}
